# Backend environment example.
# Copy to backend/.env for local development and replace any required or secret values.

# -----------------------------------------------------------------------------
# Required values
# -----------------------------------------------------------------------------

# Required: MongoDB connection string used by the NestJS app.
# Local Docker default; replace with your managed MongoDB URI outside local dev.
MONGODB_URI=mongodb://app:healtcare@mongo:27017/healtcare-agent-db?authSource=healtcare-agent-db

# Required secret: OpenAI API key used for chat/model calls.
# No safe default; set this in backend/.env or your shell env (export OPENAI_KEY=<KEY>) or set it in docker-compose.yml
OPENAI_KEY=

# -----------------------------------------------------------------------------
# Safe defaults
# -----------------------------------------------------------------------------

# Safe default: HTTP port the backend listens on inside the container/process.
PORT=8080

# Safe default for local/dev: allowed browser origins for CORS.
# Use a specific origin in shared, staging, or production environments.
CORS_ORIGIN=*

# Safe default: maximum agent tool/LLM iterations before returning a limit response.
AGENT_MAX_CAP=5

# Safe default: number of prior messages included when building agent context.
AGENT_HISTORY_CAP=10

# Safe default: OpenAI model name used when a request does not override the model.
OPENAI_MODEL=gpt-4.1-mini

# Safe default: minimum structured log level. Supported values: debug, info, warn, error.
LOG_LEVEL=info

# Safe default: S3-compatible region. MinIO accepts this value locally.
S3_REGION=us-east-1

# Safe default for MinIO and many S3-compatible services.
# Set to false only if your object store requires virtual-hosted-style buckets.
S3_FORCE_PATH_STYLE=true

# Safe default: bucket name for stored chat audio.
S3_BUCKET=chat-audio

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------

# Secret: S3 or MinIO access key.
# Local-only default matches docker-compose; replace outside local dev.
S3_ACCESS_KEY=admin

# Secret: S3 or MinIO secret key.
# Local-only default matches docker-compose; replace outside local dev.
S3_SECRET_KEY=admin123

# -----------------------------------------------------------------------------
# Local-only defaults
# -----------------------------------------------------------------------------

# Local-only default: internal S3/MinIO endpoint used by the backend container.
# Use your object-store endpoint in non-local deployments.
S3_ENDPOINT=http://minio:9000

# Local-only default: public endpoint used when generating browser-facing URLs.
# Use the externally reachable object-store URL in non-local deployments.
S3_PUBLIC_ENDPOINT=http://localhost:9000
